#!/bin/bash
# Pre-push hook - Atelier validation (≤30 seconds)

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "🚀 Running pre-push checks..."

CURRENT_BRANCH=$(git branch --show-current)
REMOTE_INFO=$(git rev-parse --abbrev-ref --symbolic-full-name @{upstream} 2>/dev/null || echo "")
REMOTE_BRANCH=$(echo "$REMOTE_INFO" | sed 's/.*\///')

echo "📍 Checking Pushing $CURRENT_BRANCH to $REMOTE_BRANCH"

# Ensure the local editable install and generated wrappers are up to date.
# Skip session import + external reports — those are slow, code-independent, and
# covered by tests; only host integrations need to be verified at push time.
echo "🛠️ Running make install (host integrations only)..."
if ! ATELIER_NO_IMPORT=1 ATELIER_STRICT=1 make install; then
    echo -e "\033[1;31m❌ make install failed. Push blocked.\033[0m"
    echo "   Fix the install error locally or use 'git push --no-verify' if you intentionally need to bypass the hook."
    exit 1
fi

# 0. Check for unauthorized .md files (atelier-specific exclusions)
echo "📄 Checking for unauthorized .md files..."
# Atelier allows: docs/, docs-archive/, reports/, .knowledge/, templates/, .ruler/, .agent/, skills/, integrations/, .github/, tests/fixtures/memory/, AGENTS*, QUICK_REFERENCE*, *_README.md, SECURITY.md, SKILL.md, LICENSE.md, CHANGELOG.md, CONTRIBUTING.md, GEMINI.md
md_files=$(git ls-files "*.md" | grep -v "^docs/" | grep -v "^docs-archive/" | grep -v "^reports/" | grep -v "^.knowledge/" | grep -v "^templates/" | grep -v "^.ruler/" | grep -v "^.agent/" | grep -v "^skills/" | grep -v "^integrations/" | grep -v "^.github/" | grep -v "^tests/fixtures/memory/" | grep -v "AGENTS" | grep -v "QUICK_REFERENCE" | grep -v "README\.md$" | grep -v "SECURITY\.md$" | grep -v "SKILL\.md$" | grep -v "_README\.md$" | grep -v "LICENSE\.md$" | grep -v "CHANGELOG\.md$" | grep -v "CONTRIBUTING\.md$" | grep -v "GEMINI\.md$" || true)

if [ -n "$md_files" ]; then
    echo -e "\033[1;31m❌ Error: Unauthorized .md files found in repository:\033[0m"
    echo "$md_files"
    echo ""
    echo "Allowed: docs/, docs-archive/, reports/, .knowledge/, templates/, .ruler/, .agent/, skills/, integrations/, .github/, tests/fixtures/memory/, AGENTS*, QUICK_REFERENCE*, README.md, SECURITY.md, SKILL.md, CHANGELOG.md, CONTRIBUTING.md, GEMINI.md"
    exit 1
fi

echo "✅ No unauthorized .md files detected."

# 1. Branch protection (prevent direct pushes to protected branches)
PROTECTED_BRANCHES=("main" "master" "production" "staging")

echo "🔍 Checking branch protection..."
for protected in "${PROTECTED_BRANCHES[@]}"; do
    if [[ "$REMOTE_BRANCH" == "$protected" ]]; then
        echo -e "\033[1;31m❌ Direct push to protected branch '$protected' is not allowed.\033[0m"
        echo "   Please create a pull request instead."
        echo "   Use 'git push --no-verify' to bypass in emergencies."
        exit 1
    fi
done

# Get changed files for pre-commit check
DIFF_BASE=
if git rev-parse --verify --quiet @{u} >/dev/null; then
    DIFF_BASE=$(git rev-parse --abbrev-ref --symbolic-full-name @{u})
elif git rev-parse --quiet origin/main >/dev/null 2>&1; then
    DIFF_BASE="origin/main"
else
    DIFF_BASE=$(git rev-list --max-parents=0 HEAD | tail -n 1)
fi

CHANGED_FILES=()
if [ -n "$DIFF_BASE" ]; then
    mapfile -t CHANGED_FILES < <(git diff --name-only --diff-filter=ACMRTUXB "$DIFF_BASE...HEAD" 2>/dev/null || true)
fi

# Validate formatting on the files being pushed (read-only, no modifications)
if [ ${#CHANGED_FILES[@]} -gt 0 ]; then
    # Filter Python files
    PYTHON_FILES=()
    for file in "${CHANGED_FILES[@]}"; do
        if [[ "$file" == *.py ]] && [[ -f "$file" ]]; then
            PYTHON_FILES+=("$file")
        fi
    done

    if [ ${#PYTHON_FILES[@]} -gt 0 ]; then
        echo "🔍 Validating Python file formatting..."

        # ruff check (lint) — read-only, no --fix
        set +e
        uv run ruff check "${PYTHON_FILES[@]}"
        RUFF_CHECK_EXIT=$?
        set -e

        # black --check (formatting) — read-only, no modification
        set +e
        uvx black --check "${PYTHON_FILES[@]}" 2>/dev/null
        BLACK_CHECK_EXIT=$?
        set -e

        if [ $RUFF_CHECK_EXIT -ne 0 ] || [ $BLACK_CHECK_EXIT -ne 0 ]; then
            echo -e "\033[1;31m❌ Formatting/lint issues detected in pushed files.\033[0m"
            echo "   Please run 'git commit' (which auto-formats) or"
            echo "   run 'uv run ruff check --fix <file>' and 'uvx black <file>' manually."
            exit 1
        fi
    fi
fi

echo "✅ Pre-push checks passed!"
echo "🚀 Pushing $CURRENT_BRANCH to $REMOTE_BRANCH..."
