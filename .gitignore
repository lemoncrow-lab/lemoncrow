# ============================================
# Atelier - Git Ignore
# ============================================

# -----------------------
# Python
# -----------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.eggs/
build/
dist/
sdist/

# Type checking
.mypy_cache/
.pytype/

# -----------------------
# Virtual Environments & uv
# -----------------------
.venv/
venv/
venv39/
.uv-cache/

# -----------------------
# Testing & Coverage
# -----------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
cover/
coverage.xml
.nyc_output/
.tox/
.nox/

# Ruff
.ruff_cache/

# -----------------------
# IDE & Editor
# -----------------------
.vscode/
.idea/
*.swp
*.swo
*~
.spell

# Claude Code
.codex/
.claude/
.antigravity/
.antigravitycli/

# Claude Desktop
.claude/

# OpenCode
.opencode/
.serena/

# Gemini CLI
.gemini/

# Github copilot workspace backups
.github/copilot-instructions.md.atelier-backup.*

# Github Copilot instructions (locally managed)
copilot-instructions.md
.github/copilot-instructions.md
cost_history.json

# VSCode test
.vscode-test/

# -----------------------
# OS Files
# -----------------------
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db

# -----------------------
# Runtime & Temp
# -----------------------
# Atelier runtime data
.atelier/

# Logs
logs/
*.log

# Temp files
tmp/
temp/
*.tmp
*.temp
*.bak
*.old
*.new.json
*.new.js

# Backup files
*.backup
*.checkpoint
deleted/*.bk/
deleted/*

# -----------------------
# Docker & Compose
# -----------------------
.dockerignore

# -----------------------
# Node / Frontend (if applicable)
# -----------------------
node_modules/
.npm
.eslintcache
.stylelintcache
.next/
.cache
.parcel-cache/

# -----------------------
# Project-Specific
# -----------------------
# Coverage/test outputs
benchmark_results/
eval_results/

# Scripts output
outputs/
results/
!docs/plans/phase-linear-cache-reuse/results/
!docs/plans/phase-linear-cache-reuse/results/**
/*.py
/*.sh

# Database dumps (ignore at root, but allow migrations)
*.sql
!src/**/*.sql
*.sqlite3
vector_cache.sqlite
dump.rdb
*.rdb

# Secrets (local dev)
.secrets/
*.local
.env
.env.local
.env.*.local

# OpenAPI client generation
frontend/src/services/stub/

# -----------------------
# Build Outputs
# -----------------------
# bin/ (unignored to support global installation wrappers)
build/Release/

# -----------------------
# MCP & Agent Configs
# -----------------------
# Ignore local workspace-level agent configs at the root
.mcp.json
.mcp.json.runtime
opencode.jsonc*
.codex/
.gemini/
.claude/
.augment/
.kilo/
.kilocode/
.clinerules/
.letta/
.agents/

# But ALWAYS track the integration templates and plugin manifests
!integrations/**/.mcp.json
!integrations/**/settings.json
!integrations/**/config.toml
!integrations/**/opencode.jsonc

# -----------------------
# Documentation Site
# -----------------------
docs-site/node_modules/
docs-site/.docusaurus/
docs-site/build/

# -----------------------
# Start Master Aggregated Rules (Global Union)
# -----------------------

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Snowpack / Vite / Parcel
.cache
.parcel-cache/
.webassets-cache

# Next.js
.next/
out/
.nuxt/
dist/
.nuxt/
dist-ssr

# Gatsby
.grunt/
.bower_components/
.gatsby/

# Node artifacts
jspm_packages/
web_modules/
node_modules/

# Bundle outputs
*.tgz
yarn-integrity
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# TypeScript
*.tsbuildinfo

# Vite config timestamp
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Serverless
.serverless/
.fusebox/
.dynamodb/
.firebase/
exports/

# TernJS
.tern-port/

# SvelteKit
.svelte-kit/

# VitePress
.vitepress/cache/
.vitepress/dist/

# -----------------------
# END Master Aggregated Rules (Global Union)
# -----------------------
.cursor/

# MCP Vector Search index directory
.mcp-vector-search/
