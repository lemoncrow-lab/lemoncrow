# self-optimization knob experiments — env overrides injected into the atelier arm.
# eval.py reads this and injects via the benchmark .env cascade (overrides the
# incontainer defaults). KEY=VALUE per line; '#' comments. One experiment = a
# minimal diff here. Empty/all-commented = atelier defaults (baseline behavior).
#
# Cost knobs (uncomment + set to run a controlled, deterministic experiment):
# ATELIER_SHELL_MAX_OUTPUT_BYTES=16384       # cap shell output, def 4MiB (H1 shell-bloat)
# ATELIER_READ_MAX_BYTES=131072              # cap read output, def 8MiB
# ATELIER_OUTLINE_THRESHOLD=400              # prefer file outline over full sooner
# ATELIER_SEARCH_BREAKER_THRESHOLD=3         # stop search/archaeology spirals sooner, def 6
# ATELIER_SEARCH_REFORMULATION_THRESHOLD=1   # def 2
# ATELIER_RECALL_CANDIDATE_LIMIT=500         # smaller recall set, def 2000
# ATELIER_CTX_NUDGE_TOKENS=                  # context-nudge threshold
#
# Already tuned by the team (measured wins) — change only to re-test:
# ATELIER_EDIT_VERIFY=1                       # -33% to -47% cost
# ATELIER_CODE_EMBEDDER=local                # prevents git-archaeology spirals
# ATELIER_HIDE_TOOLS=sql,memory,codemod,web_fetch

