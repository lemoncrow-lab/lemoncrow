# self-optimization knob experiments — env overrides injected into the lemoncrow arm.
# eval.py reads this and injects via the benchmark .env cascade (overrides the
# incontainer defaults). KEY=VALUE per line; '#' comments. One experiment = a
# minimal diff here. Empty/all-commented = lemoncrow defaults (baseline behavior).
#
# Cost knobs (uncomment + set to run a controlled, deterministic experiment):
# LEMONCROW_SHELL_MAX_OUTPUT_BYTES=16384       # cap shell output, def 4MiB (H1 shell-bloat)
# LEMONCROW_READ_MAX_BYTES=131072              # cap read output, def 8MiB
# LEMONCROW_OUTLINE_THRESHOLD=400              # prefer file outline over full sooner
# LEMONCROW_SEARCH_BREAKER_THRESHOLD=3         # stop search/archaeology spirals sooner, def 6
# LEMONCROW_SEARCH_REFORMULATION_THRESHOLD=1   # def 2
# LEMONCROW_RECALL_CANDIDATE_LIMIT=500         # smaller recall set, def 2000
# LEMONCROW_CTX_NUDGE_TOKENS=                  # context-nudge threshold
#
# Already tuned by the team (measured wins) — change only to re-test:
# LEMONCROW_EDIT_VERIFY=1                       # -33% to -47% cost
# LEMONCROW_CODE_EMBEDDER=local                # prevents git-archaeology spirals
# LEMONCROW_HIDE_TOOLS=sql,memory,codemod,web_fetch

