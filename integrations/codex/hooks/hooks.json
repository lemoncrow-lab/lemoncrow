    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LEMONCROW_AGENT=codex PYTHONPATH=\"__LEMONCROW_REPO_SRC__${PYTHONPATH:+:${PYTHONPATH}}\" \"__LEMONCROW_PYTHON__\" \"${PLUGIN_ROOT}/hooks/stop.py\""
