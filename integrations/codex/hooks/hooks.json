        "hooks": [
          {
            "type": "command",
            "command": "LEMONCROW_AGENT=codex PYTHONPATH=\"__LEMONCROW_REPO_SRC__${PYTHONPATH:+:${PYTHONPATH}}\" \"__LEMONCROW_PYTHON__\" \"${PLUGIN_ROOT}/hooks/savings_reporter.py\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LEMONCROW_AGENT=codex PYTHONPATH=\"__LEMONCROW_REPO_SRC__${PYTHONPATH:+:${PYTHONPATH}}\" \"__LEMONCROW_PYTHON__\" \"${PLUGIN_ROOT}/hooks/subagent.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LEMONCROW_AGENT=codex PYTHONPATH=\"__LEMONCROW_REPO_SRC__${PYTHONPATH:+:${PYTHONPATH}}\" \"__LEMONCROW_PYTHON__\" \"${PLUGIN_ROOT}/hooks/subagent.py\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LEMONCROW_AGENT=codex PYTHONPATH=\"__LEMONCROW_REPO_SRC__${PYTHONPATH:+:${PYTHONPATH}}\" \"__LEMONCROW_PYTHON__\" \"${PLUGIN_ROOT}/hooks/compact.py\""
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LEMONCROW_AGENT=codex PYTHONPATH=\"__LEMONCROW_REPO_SRC__${PYTHONPATH:+:${PYTHONPATH}}\" \"__LEMONCROW_PYTHON__\" \"${PLUGIN_ROOT}/hooks/compact.py\""
          }
        ]
      }
