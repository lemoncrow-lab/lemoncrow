{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "LEMONCROW_AGENT=codex PYTHONPATH=\"__LEMONCROW_REPO_SRC__${PYTHONPATH:+:${PYTHONPATH}}\" \"__LEMONCROW_PYTHON__\" \"${PLUGIN_ROOT}/hooks/update_notification.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LEMONCROW_AGENT=codex PYTHONPATH=\"__LEMONCROW_REPO_SRC__${PYTHONPATH:+:${PYTHONPATH}}\" \"__LEMONCROW_PYTHON__\" \"${PLUGIN_ROOT}/hooks/user_prompt.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LEMONCROW_AGENT=codex PYTHONPATH=\"__LEMONCROW_REPO_SRC__${PYTHONPATH:+:${PYTHONPATH}}\" \"__LEMONCROW_PYTHON__\" \"${PLUGIN_ROOT}/hooks/pre_tool_use.py\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LEMONCROW_AGENT=codex PYTHONPATH=\"__LEMONCROW_REPO_SRC__${PYTHONPATH:+:${PYTHONPATH}}\" \"__LEMONCROW_PYTHON__\" \"${PLUGIN_ROOT}/hooks/permission_request.py\""
