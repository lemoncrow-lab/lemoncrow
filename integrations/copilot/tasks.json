{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Atelier: Copilot Preflight",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "atelier tools call context --dev --args \"{\\\"task\\\":\\\"$1\\\"}\" --json",
        "bash",
        "${input:atelierTask}",
        "${input:atelierStep1}",
        "${input:atelierStep2}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Atelier: Task Context",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "atelier tools call context --dev --args \"{\\\"task\\\":\\\"$1\\\"}\" --json",
        "bash",
        "${input:atelierTask}",
        "${input:atelierStep1}",
        "${input:atelierStep2}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Atelier: Record Trace",
      "type": "shell",
      "command": "atelier",
      "args": ["runs", "record", "--task", "${input:atelierTask}", "--status", "partial", "--json"],
      "problemMatcher": []
    },
    {
      "label": "Atelier: Session Summary",
      "type": "shell",
      "command": "atelier",
      "args": ["session", "report", "--no-color"],
      "problemMatcher": []
    },
    {
      "label": "Atelier: Worktree Bootstrap",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "uv run python scripts/worktree_env.py --env-file .env.worktree --json && echo 'Use: docker compose --env-file .env.worktree up --build -d'"
      ],
      "problemMatcher": []
    },
    {
      "label": "Atelier: Runtime Evidence",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "uv run python scripts/runtime_evidence.py --base-url \"${input:atelierBaseUrl}\""
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "atelierTask",
      "type": "promptString",
      "description": "Atelier task description"
    },
    {
      "id": "atelierStep1",
      "type": "promptString",
      "description": "Plan step 1"
    },
    {
      "id": "atelierStep2",
      "type": "promptString",
      "description": "Plan step 2"
    },
    {
      "id": "atelierBaseUrl",
      "type": "promptString",
      "description": "Atelier service base URL",
      "default": "http://127.0.0.1:8787"
    }
  ]
}
