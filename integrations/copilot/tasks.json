{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "LemonCrow: Copilot Preflight",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "lc tools call context --args \"{\\\"task\\\":\\\"$1\\\"}\" --json",
        "bash",
        "${input:lemoncrowTask}",
        "${input:lemoncrowStep1}",
        "${input:lemoncrowStep2}"
      ],
      "problemMatcher": []
    },
    {
      "label": "LemonCrow: Task Context",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "lc tools call context --args \"{\\\"task\\\":\\\"$1\\\"}\" --json",
        "bash",
        "${input:lemoncrowTask}",
        "${input:lemoncrowStep1}",
        "${input:lemoncrowStep2}"
      ],
      "problemMatcher": []
    },
    {
      "label": "LemonCrow: Record Trace",
      "type": "shell",
      "command": "lc",
      "args": ["runs", "record", "--task", "${input:lemoncrowTask}", "--status", "partial", "--json"],
      "problemMatcher": []
    },
    {
      "label": "LemonCrow: Session Summary",
      "type": "shell",
      "command": "lc",
      "args": ["session", "report", "--no-color"],
      "problemMatcher": []
    },
    {
      "label": "LemonCrow: Worktree Bootstrap",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "uv run python scripts/worktree_env.py --env-file .env.worktree --json && echo 'Use: docker compose --env-file .env.worktree up --build -d'"
      ],
      "problemMatcher": []
    },
    {
      "label": "LemonCrow: Runtime Evidence",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "uv run python scripts/runtime_evidence.py --base-url \"${input:lemoncrowBaseUrl}\""
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "lemoncrowTask",
      "type": "promptString",
      "description": "LemonCrow task description"
    },
    {
      "id": "lemoncrowStep1",
      "type": "promptString",
      "description": "Plan step 1"
    },
    {
      "id": "lemoncrowStep2",
      "type": "promptString",
      "description": "Plan step 2"
    },
    {
      "id": "lemoncrowBaseUrl",
      "type": "promptString",
      "description": "LemonCrow service base URL",
      "default": "http://127.0.0.1:8787"
    }
  ]
}
