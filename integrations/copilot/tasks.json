{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Atelier: Copilot Preflight",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "atelier task --task \"$1\" --json",
        "bash",
        "${input:atelierTask}",
        "${input:atelierStep1}",
        "${input:atelierStep2}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Atelier: Task Context",
      "type": "shell",
      "command": "atelier",
      "args": [
        "task",
        "--task",
        "${input:atelierTask}",
        "--json"
      ],
      "problemMatcher": []
    },
    {
      "label": "Atelier: Record Trace",
      "type": "shell",
      "command": "atelier",
      "args": ["trace", "--task", "${input:atelierTask}", "--status", "partial", "--json"],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "atelierTask",
      "type": "promptString",
      "description": "Atelier task description"
    },
    {
      "id": "atelierStep1",
      "type": "promptString",
      "description": "Plan step 1"
    },
    {
      "id": "atelierStep2",
      "type": "promptString",
      "description": "Plan step 2"
    }
  ]
}
