{
  "mcpServers": {
    "lc": {
      "type": "stdio",
      "command": "lc",
      "args": ["mcp", "--host", "cursor"],
      "alwaysAllow": [
        "code",
        "compact",
        "context",
        "edit",
        "grep",
        "memory",
        "read",
        "rescue",
        "route",
        "search",
        "bash",
        "sql",
        "trace",
        "verify"
      ]
    }
  }
}
