{
  "model": "lc/lemoncrow",
  "provider": {
    "lc": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LemonCrow",
      "options": {
        "baseURL": "http://127.0.0.1:8787/v1",
        "apiKey": "local"
      }
    }
  },
  "mcp": {
    "lc": {
      "type": "local",
      "command": ["lemoncrow", "mcp", "--host", "opencode"],
      "environment": {
        "LEMONCROW_WORKSPACE_ROOT": "<WORKSPACE_ROOT>"
      }
    }
  }
}
